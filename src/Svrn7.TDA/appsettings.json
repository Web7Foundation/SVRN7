{
  // .NET 8 configuration — Microsoft.Extensions.Configuration.Json supports // comments.
  //
  // Logging levels (least → most verbose):
  //   None | Critical | Error | Warning | Information | Debug | Trace
  //
  // Rules: more-specific keys win over less-specific ones.
  //   "Svrn7.TDA.KestrelListenerService" beats "Svrn7.TDA" beats "Default".
  // Set an area to "Debug" or "Trace" to drill in; set to "Warning" to quiet it.

  "Logging": {
    "LogLevel": {

      // ── Catch-all ──────────────────────────────────────────────────────────
      "Default":                                        "Warning",

      // ── HTTP Listener (Kestrel — inbound POST /didcomm) ────────────────────
      "Svrn7.TDA.KestrelListenerService":               "Debug",

      // ── Switchboard (inbox drain loop + outbound delivery) ─────────────────
      "Svrn7.TDA.DIDCommMessageSwitchboard":            "Debug",
      "Svrn7.TDA.SwitchboardHostedService":             "Debug",

      // ── LOBE loader & protocol registry ────────────────────────────────────
      "Svrn7.TDA.LobeManager":                          "Information",

      // ── PowerShell Runspace Pool ────────────────────────────────────────────
      "Svrn7.TDA.IsolatedRunspaceFactory":                  "Information",

      // ── DIDComm message processing & transfer handling ─────────────────────
      "Svrn7.Society.DIDCommMessageProcessorService":   "Debug",
      "Svrn7.Society.DIDCommTransferHandler":           "Debug",

      // ── Long-Term Message Memory (inbox / outbox / processed orders) ────────
      "Svrn7.Society.LiteInboxStore":                   "Warning",
      "Svrn7.Society.InboxLiteContext":                 "Warning",

      // ── DID resolution & VC document resolution ─────────────────────────────
      "Svrn7.Society.FederationDidDocumentResolver":    "Warning",
      "Svrn7.Society.FederationVcDocumentResolver":     "Warning",

      // ── Society driver (citizen registration, transfers, overdraft) ─────────
      "Svrn7.Society.Svrn7SocietyDriver":               "Warning",

      // ── Federation driver (wallets, Merkle log, DID governance) ────────────
      "Svrn7.Federation.Svrn7Driver":                   "Debug", // DID Document tracing
      "Svrn7.Federation.Svrn7BackgroundService":        "Warning",

      // ── Schema registry ─────────────────────────────────────────────────────
      "Svrn7.Society.LiteSchemaRegistry":               "Warning",

      // ── LiteDB database contexts (open/close, connection strings) ───────────
      "Svrn7.Store":                                    "Information",

      // ── ASP.NET Core / Kestrel infrastructure ─────────────────────────────────
      "Microsoft.AspNetCore":                           "Error",

      // ── .NET host infrastructure ─────────────────────────────────────────────
      "Microsoft":                                      "Warning",
      "Microsoft.Extensions.Hosting":                   "Warning"
    }
  },

  // ── TDA configuration ─────────────────────────────────────────────────────
  // All keys can be overridden by environment variables (Tda__Role etc.)
  // or by command-line arguments (--role Federation).
  "Tda": {
    // Role: Federation | Society | Citizen
    // Declares the functional role of this TDA instance. Default: Federation.
    "Role": "Federation"
  }
}
